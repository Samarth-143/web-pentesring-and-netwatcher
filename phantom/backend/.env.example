# PHANTOM Backend Environment Variables

# Redis Connection (Required for Celery and Rate Limiting)
REDIS_URL=redis://localhost:6379/0

# JWT Secret Key (If blank, a random one is generated on startup)
PHANTOM_SECRET=my_super_secret_key_change_me

# Allowed Frontend Origins (Comma separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Frontend URL (Used for OAuth Redirects)
FRONTEND_URL=http://localhost:5173

# ----------------------------------------------------
# OAuth Credentials
# ----------------------------------------------------

# Google OAuth Setup:
# 1. Go to https://console.cloud.google.com/
# 2. Create a project and setup OAuth Consent Screen
# 3. Create OAuth 2.0 Client IDs
# 4. Add Redirect URI: http://127.0.0.1:8000/auth/google/callback
GOOGLE_CLIENT_ID=857326209081-1iopo3r1a0kv7jtg5tcbus0rdr2aq0p0.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# GitHub OAuth Setup:
# 1. Go to https://github.com/settings/developers
# 2. Register a new OAuth application
# 3. Authorization callback URL: http://127.0.0.1:8000/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
