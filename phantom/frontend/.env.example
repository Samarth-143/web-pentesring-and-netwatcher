# PHANTOM Frontend Configuration Template

# Base URL for the FastAPI backend REST API
# In Docker or Nginx reverse proxy, use '/api' to proxy to backend.
# In local dev (npm run dev), use 'http://localhost:8000'
VITE_API_BASE=http://localhost:8000

# WebSocket URL for streaming live packet telemetry from Net-Watch
# In Docker or Nginx reverse proxy, use 'ws://<host>/ws/traffic'
# In local dev, use 'ws://localhost:8000/ws/traffic'
VITE_WS_URL=ws://localhost:8000/ws/traffic
